DEEPGRAM_API_KEY=your_deepgram_api_key_here
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TEXTBELT_API_KEY=your_textbelt_api_key_here
# Twilio kept around in case A2P 10DLC registration gets sorted out later
# (confirmation/service.py currently defaults to Textbelt, not these).
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_phone_number_here

# Telephony voicemail (phone call -> voicemail -> STT -> intake)
# Revert path: set TELEPHONY_PROVIDER=twilio and point the number webhook back here.
TELEPHONY_PROVIDER=twilio
# Public HTTPS base URL the provider uses to reach this server (ngrok URL in dev, app URL in prod).
PUBLIC_BASE_URL=https://your-public-host.example.com
# Set to false only for local testing without a real provider request signature.
TELEPHONY_VALIDATE_SIGNATURE=true
# Optional overrides:
# TELEPHONY_RECORDING_FORMAT=wav
# TELEPHONY_MAX_RECORDING_SECONDS=120
# TELEPHONY_GREETING=Custom greeting played before the beep.
# VOICEMAIL_OUTPUT_DIR=telephony_output

# SignalWire provider (used when TELEPHONY_PROVIDER=signalwire)
SIGNALWIRE_PROJECT_ID=your_signalwire_project_id_here
SIGNALWIRE_API_TOKEN=your_signalwire_api_token_here
SIGNALWIRE_SIGNING_KEY=your_signalwire_signing_key_here
