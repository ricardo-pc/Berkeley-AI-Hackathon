DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Supabase (server-side only — used by the EHR data layer).
# Same project as backend/api/.env. The service role key bypasses RLS, so it
# must never be exposed to the browser (only read in route handlers / server
# components). Copy values into .env.local (gitignored).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
